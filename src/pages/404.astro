---
import Layout from "@/layouts/Layout.astro"
---

<Layout title="404 Not Found - Gen's Portfolio">
  <div style="min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:var(--content-padding);text-align:center">
    <p style="font-family:var(--font-mono);font-size:11px;color:var(--text-subtle);letter-spacing:0.16em;margin-bottom:16px">404</p>
    <h1 style="font-family:var(--font-display);font-size:clamp(48px,10vw,80px);font-weight:900;color:var(--text-primary);letter-spacing:-0.04em;margin-bottom:24px">Not Found</h1>
    <p style="font-family:var(--font-body);font-size:15px;color:var(--text-muted);margin-bottom:40px">
      お探しのページは見つかりませんでした。
    </p>
    <a href="/" style="font-family:var(--font-mono);font-size:12px;color:var(--text-body);text-decoration:none;border:1px solid var(--border);padding:12px 28px;transition:all 0.25s ease" class="home-link">
      ← トップへ戻る
    </a>
  </div>
</Layout>

<style>
  .home-link:hover {
    border-color: var(--border-hover);
    color: var(--text-primary);
  }
</style>
