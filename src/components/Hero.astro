---
import { SOCIALS } from "@/data/socials"
import { LATEST_ACTIVITIES } from "@/data/about"
import { SECTIONS } from "@/data/sections"
---

<header class="hero-pad" style="min-height:100vh;display:flex;flex-direction:column;justify-content:flex-end;padding:0 var(--content-padding) 72px;position:relative;overflow:hidden">
  <!-- Grain texture -->
  <div style="position:absolute;inset:0;opacity:var(--hero-grain-opacity);background-image:url(\"data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E\");pointer-events:none" />

  <!-- Hero content -->
  <div style="max-width:820px;animation:heroFadeUp 0.9s ease forwards">
    <p style="font-family:var(--font-mono);font-size:12px;color:var(--text-subtle);font-weight:500;letter-spacing:0.16em;margin-bottom:20px">PORTFOLIO</p>
    <h1 class="hero-title" style="font-family:var(--font-display);font-size:clamp(56px,10vw,100px);font-weight:900;line-height:1;color:var(--text-primary);letter-spacing:-0.04em">Gen</h1>
    <p style="font-family:var(--font-body);font-size:15px;color:var(--text-muted);margin-top:20px;line-height:1.8;max-width:460px">
      Cyclist — Technical Writer — Doujinshi Publisher<br />
      同人サークル「幻想サイクル」主宰 / 東方同人音楽ライター
    </p>

    <!-- Social links -->
    <div style="display:flex;gap:20px;margin-top:28px">
      {SOCIALS.map(s => (
        <a href={s.url} target="_blank" rel="noopener noreferrer" title={s.name} aria-label={s.name}
          class="social-link" style="color:var(--text-muted);transition:color 0.2s;font-family:var(--font-mono);font-size:13px;text-decoration:none">
          {s.name}
        </a>
      ))}
    </div>

    <!-- Latest Activity -->
    <div style="margin-top:48px;padding-top:32px;border-top:1px solid var(--border)">
      <div style="display:flex;align-items:baseline;gap:12px;margin-bottom:20px">
        <h2 style="font-family:var(--font-mono);font-size:12px;font-weight:600;color:var(--text-muted);letter-spacing:0.14em;margin:0">LATEST</h2>
      </div>
      <div style="display:flex;flex-direction:column;gap:0">
        {LATEST_ACTIVITIES.map(a => (
          <a href={a.link} target="_blank" rel="noopener noreferrer"
            class="latest-item" style="display:flex;gap:16px;padding:16px 0;border-bottom:1px solid var(--border);text-decoration:none;color:inherit">
            <div style="flex-shrink:0;width:64px">
              <span style="font-family:var(--font-mono);font-size:12px;color:var(--text-muted);font-weight:500">{a.date}</span>
            </div>
            <div style="flex:1;min-width:0">
              <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap">
                <span class="latest-title" style="font-family:var(--font-display);font-size:15px;font-weight:600;color:var(--text-body);transition:color 0.2s">{a.title}</span>
                <span style="font-family:var(--font-mono);font-size:10px;letter-spacing:0.08em;color:var(--accent);padding:2px 8px;border:1px solid var(--accent-border);font-weight:600">{a.tag}</span>
              </div>
              <p style="font-family:var(--font-body);font-size:13px;color:var(--text-muted);margin:4px 0 0;line-height:1.6">{a.desc}</p>
            </div>
            <span class="latest-arrow" style="font-size:14px;color:var(--text-subtle);transition:all 0.2s;flex-shrink:0;align-self:center">→</span>
          </a>
        ))}
      </div>

      <!-- Section jump buttons -->
      <div style="margin-top:24px;display:flex;gap:12px;flex-wrap:wrap">
        {SECTIONS.map(s => (
          <a href={`#${s.id}`} class="jump-btn" style="font-family:var(--font-mono);font-size:11px;color:var(--text-muted);text-decoration:none;border:1px solid var(--border);padding:7px 16px;transition:all 0.2s;letter-spacing:0.06em">
            {s.label} ↓
          </a>
        ))}
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div style="position:absolute;bottom:24px;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:6px;animation:drift 2.5s infinite">
    <span style="font-family:var(--font-mono);font-size:9px;color:var(--text-subtle);letter-spacing:0.14em">SCROLL</span>
    <div style="width:1px;height:20px;background:var(--border-hover)" />
  </div>
</header>

<style>
  .social-link:hover { color: var(--text-primary); }
  .latest-item:hover .latest-title { color: var(--text-primary); }
  .latest-item:hover .latest-arrow { color: var(--text-muted); transform: translateX(3px); }
  .jump-btn:hover { color: var(--text-primary); border-color: var(--border-hover); }
</style>
