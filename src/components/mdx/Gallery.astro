---
// CSS scroll-snap ベースのギャラリーコンポーネント
// 注意: MDX が <p><figure>...</figure></p> という無効 HTML を生成するため、
// ブラウザが <p> と <figure> を別要素に分解する。
// → JS でイメージを含む要素だけをスライドとして扱い、空 <p> を無視する。
---

<div class="gallery" role="region" aria-label="サンプルページ" tabindex="0">
  <div class="gallery-track">
    <slot />
  </div>
  <div class="gallery-indicator" aria-hidden="true"></div>
</div>

<style>
  .gallery {
    position: relative;
    margin: 2rem calc(-1 * var(--content-padding, 0px));
  }

  .gallery-track {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .gallery-track::-webkit-scrollbar { display: none; }

  /* MDX が生成する空 <p> を非表示にして flex アイテムから除外 */
  .gallery-track > :global(p) {
    display: none;
  }

  /* figure や img が直接 track の子になった場合もスライドとして機能する */
  .gallery-track > :global(figure),
  .gallery-track > :global(.gallery-slide) {
    flex: 0 0 100%;
    scroll-snap-align: start;
    margin: 0;
    display: flex;
    justify-content: center;
    align-items: center;
    background: var(--surface);
    min-height: 200px;
  }

  .gallery-track > :global(figure) :global(img),
  .gallery-track > :global(.gallery-slide) :global(img) {
    max-height: 70vh;
    width: auto;
    max-width: 100%;
    object-fit: contain;
    display: block;
  }

  /* Astro Picture コンポーネントが生成する <picture> も対応 */
  .gallery-track > :global(figure) :global(picture),
  .gallery-track > :global(.gallery-slide) :global(picture) {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
    max-height: 70vh;
  }

  .gallery-indicator {
    display: flex;
    justify-content: center;
    gap: 6px;
    padding: 12px 0;
  }
  .gallery-indicator :global(.dot) {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--text-subtle);
    transition: background 0.2s;
    cursor: pointer;
  }
  .gallery-indicator :global(.dot.active) {
    background: var(--text-primary);
  }

  @media (max-width: 640px) {
    .gallery {
      margin-left: calc(-1 * var(--content-padding, 20px));
      margin-right: calc(-1 * var(--content-padding, 20px));
    }
  }
</style>

<script>
  document.querySelectorAll('.gallery').forEach(gallery => {
    const track = gallery.querySelector('.gallery-track') as HTMLElement | null
    const indicator = gallery.querySelector('.gallery-indicator') as HTMLElement | null
    if (!track || !indicator) return

    // MDX が生成する空 <p> を除外し、img/picture を含む要素だけをスライドとして使う
    const items = Array.from(track.children).filter(el =>
      el.querySelector('img, picture') !== null
    )

    if (items.length === 0) return

    // スライドに CSS クラスを付与（figure や直接の img にも適用される）
    items.forEach(el => {
      if (!el.classList.contains('gallery-slide')) {
        el.classList.add('gallery-slide')
      }
    })

    if (items.length <= 1) return

    // インジケータードットを生成
    items.forEach((_, i) => {
      const dot = document.createElement('span')
      dot.className = i === 0 ? 'dot active' : 'dot'
      indicator.appendChild(dot)
    })
    const dots = Array.from(indicator.querySelectorAll('.dot'))

    // スクロール位置に応じてアクティブドットを更新
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const idx = items.indexOf(entry.target as Element)
            if (idx !== -1) {
              dots.forEach((d, i) => d.classList.toggle('active', i === idx))
            }
          }
        })
      },
      { root: track, threshold: 0.5 }
    )

    items.forEach(item => observer.observe(item))

    // ドットクリックでスライド移動
    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => {
        items[i]?.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'start' })
      })
    })
  })
</script>
