---
// CSS scroll-snap ベースのギャラリーコンポーネント
---

<div class="gallery" role="region" aria-label="サンプルページ" tabindex="0">
  <div class="gallery-track">
    <slot />
  </div>
  <div class="gallery-indicator" aria-hidden="true"></div>
</div>

<style>
  .gallery {
    position: relative;
    margin: 2rem calc(-1 * var(--content-padding, 0px));
  }

  .gallery-track {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .gallery-track::-webkit-scrollbar { display: none; }

  /* MDX + Mdxpicture が生成する空 <p> を非表示 */
  .gallery-track > :global(p) {
    display: none;
  }

  /* JS が付与する .gallery-slide を1枚分の幅にする */
  .gallery-track > :global(.gallery-slide) {
    flex: 0 0 100%;
    scroll-snap-align: start;
    margin: 0;
    display: flex;
    justify-content: center;
    align-items: center;
    background: var(--surface);
    min-height: 200px;
  }

  .gallery-track > :global(.gallery-slide) :global(img) {
    max-height: 70vh;
    width: auto;
    max-width: 100%;
    object-fit: contain;
    display: block;
  }

  .gallery-track > :global(.gallery-slide) :global(picture) {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
  }

  /* ── インジケーター ── */
  .gallery-indicator {
    display: flex;
    justify-content: center;
    align-items: center;
    /* gap はゼロ — ドットボタン側の padding で間隔を確保 */
  }

  /* ドットの視覚要素 (.dot-inner) */
  .gallery-indicator :global(.dot-inner) {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--text-subtle);
    transition: background 0.25s, transform 0.25s;
    pointer-events: none;
  }

  /* ドットのクリック領域 (.dot-btn): 44×44px の透明ボタン */
  .gallery-indicator :global(.dot-btn) {
    width: 44px;
    height: 44px;
    border: none;
    background: transparent;
    cursor: pointer;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    -webkit-tap-highlight-color: transparent;
  }

  .gallery-indicator :global(.dot-btn.active) :global(.dot-inner) {
    background: var(--text-primary);
    transform: scale(1.35);
  }

  .gallery-indicator :global(.dot-btn:hover) :global(.dot-inner) {
    background: var(--text-body);
  }

  @media (max-width: 640px) {
    .gallery {
      margin-left: calc(-1 * var(--content-padding, 20px));
      margin-right: calc(-1 * var(--content-padding, 20px));
    }
  }
</style>

<script>
  function initGalleries() {
    document.querySelectorAll('.gallery').forEach(gallery => {
      // 二重初期化を防ぐ
      if ((gallery as HTMLElement).dataset.initialized === '1') return
      ;(gallery as HTMLElement).dataset.initialized = '1'

      const track = gallery.querySelector('.gallery-track') as HTMLElement | null
      const indicator = gallery.querySelector('.gallery-indicator') as HTMLElement | null
      if (!track || !indicator) return

      // MDX が生成する空 <p> を除外し、img / picture を含む要素だけをスライドとして扱う
      const items = Array.from(track.children).filter(el =>
        el.querySelector('img, picture') !== null
      )
      if (items.length === 0) return

      // スライドクラスを付与して CSS を適用
      items.forEach(el => el.classList.add('gallery-slide'))

      if (items.length <= 1) return

      // ── インジケータードット生成 ──
      items.forEach((_, i) => {
        const btn = document.createElement('button')
        btn.type = 'button'
        btn.className = i === 0 ? 'dot-btn active' : 'dot-btn'
        btn.setAttribute('aria-label', `スライド ${i + 1}`)

        const inner = document.createElement('span')
        inner.className = 'dot-inner'
        btn.appendChild(inner)
        indicator.appendChild(btn)
      })

      const btns = Array.from(indicator.querySelectorAll<HTMLButtonElement>('.dot-btn'))

      // ── スクロール連動でドットをアクティブにする ──
      const slideObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach(entry => {
            if (!entry.isIntersecting) return
            const idx = items.indexOf(entry.target as Element)
            if (idx === -1) return
            btns.forEach((b, i) => b.classList.toggle('active', i === idx))
          })
        },
        { root: track, threshold: 0.5 }
      )
      items.forEach(item => slideObserver.observe(item))

      // ── ドットクリックでスライド移動 ──
      btns.forEach((btn, i) => {
        btn.addEventListener('click', () => {
          items[i]?.scrollIntoView({
            behavior: 'smooth',
            block: 'nearest',
            inline: 'start',
          })
        })
      })
    })
  }

  // 初回ロード（通常のページ表示）
  initGalleries()

  // ClientRouter (View Transitions) でのページ遷移後も再実行
  document.addEventListener('astro:page-load', () => {
    // data-initialized をリセットして再初期化できるようにする
    document.querySelectorAll('.gallery[data-initialized]').forEach(el => {
      delete (el as HTMLElement).dataset.initialized
    })
    initGalleries()
  })
</script>
