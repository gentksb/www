---
interface Props {
  item: { title: string; url: string; desc: string }
  delay?: number
}
const { item, delay = 0 } = Astro.props
---

<a
  href={item.url}
  target="_blank"
  rel="noopener noreferrer"
  class="link-item slide-in"
  style={`display:flex;justify-content:space-between;align-items:center;padding:16px 0;border-bottom:1px solid var(--border);text-decoration:none;color:inherit;transition-delay:${delay}s`}
>
  <div>
    <div class="link-title" style="font-family:var(--font-display);font-size:15px;font-weight:600;color:var(--text-body);transition:color 0.2s">
      {item.title}
    </div>
    <div style="font-family:var(--font-body);font-size:12px;color:var(--text-muted);margin-top:3px">
      {item.desc}
    </div>
  </div>
  <span class="link-arrow" style="font-size:14px;color:var(--text-subtle);transition:all 0.2s;flex-shrink:0;margin-left:12px">↗</span>
</a>

<style>
  .link-item:hover .link-title { color: var(--text-primary); }
  .link-item:hover .link-arrow { color: var(--text-muted); transform: translateX(3px); }
</style>
