---
import SectionHeading from "@/components/ui/SectionHeading.astro"
import LinkItem from "@/components/cards/LinkItem.astro"
import { LINKS_DATA } from "@/data/links"

const totalLinks = LINKS_DATA.reduce((a, c) => a + c.items.length, 0)
---

<section id="links" class="section-pad" style="padding:100px var(--content-padding) 80px;max-width:960px;margin:0 auto">
  <SectionHeading label="LINKS" sub="ブログ・外部プラットフォーム" count={`${totalLinks} links`} />
  <div class="about-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:0 56px">
    {LINKS_DATA.map((group, gi) => (
      <div style="margin-bottom:32px">
        <h3 style="font-family:var(--font-mono);font-size:12px;font-weight:600;color:var(--text-muted);letter-spacing:0.1em;margin-bottom:8px">
          {group.cat.toUpperCase()}
        </h3>
        {group.items.map((item, ii) => (
          <LinkItem item={item} delay={gi * 0.05 + ii * 0.04} />
        ))}
      </div>
    ))}
  </div>
</section>
